From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: amal <amalshaji645@gmail.com>
Date: Wed, 24 Jun 2026 05:50:00 +0530
Subject: [PATCH 19/19] Add AutoPie bootstrap download task

---
 app/build.gradle | 85 ++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 85 insertions(+)

diff --git a/app/build.gradle b/app/build.gradle
index 04f8d4a4..edc287ee 100644
--- a/app/build.gradle
+++ b/app/build.gradle
@@ -141,0 +142,85 @@ def validateVersionName(String versionName) {
+
+def downloadAutoPieBootstrapArchive(String arch, String expectedChecksum, String version) {
+    def digest = java.security.MessageDigest.getInstance("SHA-256")
+    def localUrl = "src/main/cpp/bootstrap-" + arch + ".zip"
+    def file = new File(projectDir, localUrl)
+
+    if (file.exists()) {
+        def buffer = new byte[8192]
+        def input = new FileInputStream(file)
+        try {
+            while (true) {
+                def readBytes = input.read(buffer)
+                if (readBytes < 0) break
+                digest.update(buffer, 0, readBytes)
+            }
+        } finally {
+            input.close()
+        }
+
+        def checksum = new BigInteger(1, digest.digest()).toString(16)
+        while (checksum.length() < 64) { checksum = "0" + checksum }
+        if (checksum == expectedChecksum) {
+            logger.quiet("Using existing " + localUrl)
+            return
+        }
+
+        logger.quiet("Deleting old local file with wrong hash: " + localUrl + ": expected: " + expectedChecksum + ", actual: " + checksum)
+        file.delete()
+    }
+
+    def remoteUrl = "https://github.com/termux/termux-packages/releases/download/bootstrap-" + version + "/bootstrap-" + arch + ".zip"
+    logger.quiet("Downloading " + remoteUrl + " ...")
+
+    file.parentFile.mkdirs()
+    def out = new BufferedOutputStream(new FileOutputStream(file))
+
+    def connection = new URL(remoteUrl).openConnection()
+    connection.setInstanceFollowRedirects(true)
+    def digestStream = new java.security.DigestInputStream(connection.inputStream, digest)
+    try {
+        out << digestStream
+    } finally {
+        out.close()
+        digestStream.close()
+    }
+
+    def checksum = new BigInteger(1, digest.digest()).toString(16)
+    while (checksum.length() < 64) { checksum = "0" + checksum }
+    if (checksum != expectedChecksum) {
+        file.delete()
+        throw new GradleException("Wrong checksum for " + remoteUrl + ": expected: " + expectedChecksum + ", actual: " + checksum)
+    }
+}
+
+tasks.register("downloadAutoPieBootstrap") {
+    doLast {
+        def arch = System.getenv("AUTOPIE_BOOTSTRAP_ARCH") ?: "aarch64"
+        def bootstrapVersions = [
+            "apt-android-7": [
+                version: "2026.02.12-r1" + "%2B" + "apt.android-7",
+                checksums: [
+                    aarch64: "ea2aeba8819e517db711f8c32369e89e7c52cee73e07930ff91185e1ab93f4f3",
+                    arm: "a38f4d3b2f735f83be2bf54eff463e86dc32a3e2f9f861c1557c4378d249c018",
+                    i686: "f5bc0b025b9f3b420b5fcaeefc064f888f5f22a0d6fd7090f4aac0c33eb3555b",
+                    x86_64: "b7fd0f2e3a4de534be3144f9f91acc768630fc463eaf134ab2e64c545e834f7a",
+                ],
+            ],
+            "apt-android-5": [
+                version: "2022.04.28-r6" + "+" + "apt-android-5",
+                checksums: [
+                    aarch64: "913609d439415c828c5640be1b0561467e539cb1c7080662decaaca2fb4820e7",
+                    arm: "26bfb45304c946170db69108e5eb6e3641aad751406ce106c80df80cad2eccf8",
+                    i686: "46dcfeb5eef67ba765498db9fe4c50dc4690805139aa0dd141a9d8ee0693cd27",
+                    x86_64: "615b590679ee6cd885b7fd2ff9473c845e920f9b422f790bb158c63fe42b8481",
+                ],
+            ],
+        ]
+        def bootstrap = bootstrapVersions[project.ext.packageVariant]
+        if (bootstrap == null) throw new GradleException("Unsupported TERMUX_PACKAGE_VARIANT \"" + project.ext.packageVariant + "\"")
+        def checksum = bootstrap.checksums[arch]
+        if (checksum == null) throw new GradleException("Unsupported bootstrap arch \"" + arch + "\"")
+
+        downloadAutoPieBootstrapArchive(arch, checksum, bootstrap.version)
+    }
+}
+}
