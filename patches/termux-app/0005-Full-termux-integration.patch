-        return getZip();
+//    public static byte[] loadZipBytes() {
+//        Logger.logError("BOOTSTRAP", "Before loadLibrary");
+//        System.loadLibrary("termux-bootstrap");
+//        Logger.logError("BOOTSTRAP", "After loadLibrary");
+//
