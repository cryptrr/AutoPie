#!/system/bin/sh

set -eu

CONTENT_BIN="${CONTENT_BIN:-/system/bin/content}"
AUTOPIE_SECRET_AUTHORITY="${AUTOPIE_SECRET_AUTHORITY:-${AUTOPIE_PACKAGE:-com.autopi}.secrets}"
AUTOPIE_SECRET_URI="content://${AUTOPIE_SECRET_AUTHORITY}"

usage() {
    cat >&2 <<USAGE
Usage:
  autopie-secret get key
  autopie-secret set key [value]
  autopie-secret delete key

If value is omitted for set, it is read from stdin.
USAGE
}

uri_encode() {
    python - "$1" <<'PY'
from urllib.parse import quote
import sys

print(quote(sys.argv[1], safe=""))
PY
}

require_key() {
    if [ "$#" -ne 1 ] || [ -z "$1" ]; then
        usage
        exit 2
    fi
}

if [ "$#" -lt 1 ]; then
    usage
    exit 2
fi

command="$1"
shift

case "$command" in
    get)
        require_key "$@"
        encoded_key="$(uri_encode "$1")"
        output="$("$CONTENT_BIN" query --uri "$AUTOPIE_SECRET_URI/$encoded_key" --projection value)"
        if printf '%s\n' "$output" | grep -q '^No result found\.$'; then
            exit 1
        fi
        printf '%s\n' "$output" | sed -n 's/^Row: [0-9][0-9]* value=//p'
        ;;
    set)
        if [ "$#" -lt 1 ] || [ -z "$1" ] || [ "$#" -gt 2 ]; then
            usage
            exit 2
        fi
        key="$1"
        if [ "$#" -eq 2 ]; then
            value="$2"
        else
            value="$(cat)"
        fi
        encoded_key="$(uri_encode "$key")"
        "$CONTENT_BIN" insert --uri "$AUTOPIE_SECRET_URI/$encoded_key" --bind value:s:"$value" >/dev/null
        ;;
    delete)
        require_key "$@"
        encoded_key="$(uri_encode "$1")"
        "$CONTENT_BIN" delete --uri "$AUTOPIE_SECRET_URI/$encoded_key" >/dev/null
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage
        exit 2
        ;;
esac
